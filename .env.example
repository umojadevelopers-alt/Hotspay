# =============================================================================
# Hotspay MikroTik Hotspot Billing System - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=3000
APP_NAME=Hotspay
APP_URL=http://localhost:3000

# Default language: en | sw | fr
DEFAULT_LANGUAGE=en

# CORS: comma-separated origins, or * to allow all
CORS_ORIGIN=*

# -----------------------------------------------------------------------------
# Database (MySQL)
# -----------------------------------------------------------------------------
DB_HOST=https://hotspay.vps.webdock.cloud
DB_PORT=3306
DB_NAME=hotspay
DB_USER=hotspay
DB_PASSWORD=Q6PxgnBxtMEa
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# -----------------------------------------------------------------------------
# JWT Authentication
# -----------------------------------------------------------------------------
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change_this_to_another_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# -----------------------------------------------------------------------------
# MikroTik RouterOS API
# -----------------------------------------------------------------------------
# Default router (can be overridden per-router in the database)
MIKROTIK_HOST=192.168.88.1
MIKROTIK_PORT=8728
MIKROTIK_USER=admin
MIKROTIK_PASSWORD=your_mikrotik_password
# TLS/SSL for RouterOS API (true | false)
MIKROTIK_TLS=false
# Connection timeout in milliseconds
MIKROTIK_TIMEOUT=5000

# -----------------------------------------------------------------------------
# SMS - Africa's Talking
# -----------------------------------------------------------------------------
AT_API_KEY=your_africastalking_api_key
AT_USERNAME=sandbox
AT_SENDER_ID=Hotspay
# Set to true to enable SMS notifications
SMS_ENABLED=false

# -----------------------------------------------------------------------------
# Email - SMTP (Nodemailer)
# -----------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_email_app_password
SMTP_FROM_NAME=Hotspay
SMTP_FROM_EMAIL=noreply@hotspay.com
# Set to true to enable email notifications
EMAIL_ENABLED=false

# -----------------------------------------------------------------------------
# File Uploads
# -----------------------------------------------------------------------------
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=5

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
# Comma-separated list of allowed IPs for API access (leave empty to allow all)
# Example: ALLOWED_IPS=127.0.0.1,192.168.1.10,10.0.0.5
ALLOWED_IPS=

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# bcrypt salt rounds
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# Hotspot Portal
# -----------------------------------------------------------------------------
# URL of the MikroTik hotspot login page (for redirect after purchase)
HOTSPOT_LOGIN_URL=http://192.168.88.1/login
# Hotspot portal session cookie secret
SESSION_SECRET=change_this_session_secret

# -----------------------------------------------------------------------------
# Payments
# -----------------------------------------------------------------------------
# M-Pesa (Safaricom Daraja)
MPESA_CONSUMER_KEY=your_mpesa_consumer_key
MPESA_CONSUMER_SECRET=your_mpesa_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback
MPESA_ENV=sandbox

# Airtel Money
AIRTEL_CLIENT_ID=your_airtel_client_id
AIRTEL_CLIENT_SECRET=your_airtel_client_secret
AIRTEL_ENV=sandbox

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=info
LOG_DIR=logs

# -----------------------------------------------------------------------------
# WireGuard (managed via MikroTik RouterOS API)
# -----------------------------------------------------------------------------
# Set to true to enable WireGuard API endpoints
WIREGUARD_ENABLED=true
